# ============================================================
# БЛОК 1: НАСЛЕДОВАНИЕ
# ============================================================
extends Area2D

# ============================================================
# БЛОК 2: ПЕРЕМЕННЫЕ (меняй здесь)
# ============================================================
var items = []
var despawn_timer = 30.0

# ============================================================
# БЛОК 3: СОЗДАНИЕ
# ============================================================
func _ready():
	print("💀 Обломки созданы")
	body_entered.connect(_on_body_entered)

func setup(wreck_items):
	items = wreck_items

# ============================================================
# БЛОК 4: ЛОГИКА
# ============================================================
func _process(delta):
	despawn_timer -= delta
	if despawn_timer <= 0:
		queue_free()

func _on_body_entered(body):
	if body.name == "PlayerShip":
		collect()

func collect():
	print("📦 Обломки собраны")
	queue_free()
